<?xml version="1.0" encoding="UTF-8"?>
<!-- Entitlements for the Developer-ID-signed, notarized release.
     Unlike the dev entitlements, this OMITS disable-library-validation:
     once the whole bundle (app + Sparkle) is re-signed under one Developer
     ID team, library validation passes on its own, so weakening it is both
     unnecessary and worse hygiene. Never contains get-task-allow. -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.security.app-sandbox</key>
	<false/>
	<key>com.apple.security.network.client</key>
	<true/>
</dict>
</plist>
